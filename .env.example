# ============================================================
# BizilCore — Environment Variables Template
# Private repo — safe to commit
#
# Localhost setup:
#   cp .env.example .env
#   .env ফাইলে values fill করুন
#
# Replit: Secrets tab-এ একবার দিলেই চিরকাল থাকে
# ============================================================

# --- Database (Supabase — সব জায়গায় একই DB) ---
# Supabase → Connect button → Transaction tab থেকে copy করুন
# Port অবশ্যই 6543 হতে হবে (Transaction pooler — app runtime)
SUPABASE_DATABASE_URL="postgresql://postgres.YOURREF:YOURPASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"
# Optional: session/direct URL for migrations (port 5432). If omitted, prisma.config.ts uses 5432 from the URL above.
# SUPABASE_DIRECT_URL="postgresql://postgres.YOURREF:YOURPASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# --- Auth ---
# ⚠️ PRODUCTION: নিচের dev value ব্যবহার করবেন না — নতুন secret generate করুন:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# (এই value শুধু local dev-এর জন্য; এটি public repo-তে থাকায় production-এ অবশ্যই বদলান)
AUTH_SECRET="8371665139ac5457f09fa184a4737e896460968eaaefe3e360034f2ea82cba73"
NEXTAUTH_SECRET="8371665139ac5457f09fa184a4737e896460968eaaefe3e360034f2ea82cba73"
NEXTAUTH_URL="http://localhost:5000"

# --- App URLs ---
NEXT_PUBLIC_APP_URL="http://localhost:5000"
NEXT_PUBLIC_BASE_URL="http://localhost:5000"

# --- Local dev performance (Windows: slow F: drive cache → local SSD) ---
# Set in .env.local to speed up `next dev` on network/slow drives:
# NEXT_DIST_DIR=C:/Users/YourName/AppData/Local/Temp/bizilcore-next
# ENABLE_INSTRUMENTATION_CRON=true  # only if you need Replit-style cron locally

# --- Cloudinary (Image Upload) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- AI ---
OPENROUTER_API_KEY=""
OPENAI_API_KEY=""

# --- Email ---
EMAIL_FROM_NAME="BizilCore"
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_RESEND_API_KEY=""

# --- bKash ---
BKASH_BASE_URL="https://tokenized.pay.bka.sh/v1.2.0-beta"
BKASH_USERNAME=""
BKASH_PASSWORD=""
BKASH_APP_KEY=""
BKASH_APP_SECRET=""

# --- Nagad ---
NAGAD_BASE_URL="https://api.mynagad.com/remote-payment-gateway-1.0"
NAGAD_MERCHANT_ID=""
NAGAD_MERCHANT_PRIVATE_KEY=""
NAGAD_PUBLIC_KEY=""

# --- ZiniPay (personal number auto-verification) ---
ZINIPAY_API_KEY=""
ZINIPAY_ENABLED="true"
ZINIPAY_BKASH_NUMBER=""
ZINIPAY_NAGAD_NUMBER=""
ZINIPAY_ROCKET_NUMBER=""

# --- SMS ---
# Platform master key for credit-based SMS (sms.net.bd)
SMS_PLATFORM_API_KEY=""
SSL_WIRELESS_URL="https://sms.sslwireless.com/pushapi/dynamic/server.php"
SSL_WIRELESS_API_KEY=""
SSL_WIRELESS_SENDER_ID=""

# --- eCourier ---
ECOURIER_API_KEY=""
ECOURIER_API_SECRET=""
ECOURIER_USER_ID=""
ECOURIER_PICKUP_ADDRESS=""

# --- Facebook ---
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_VERIFY_TOKEN=""

# --- Meta Integrations (Facebook Page / Instagram / WhatsApp connect) ---
# Meta Developer Console → আপনার App → Settings → Basic থেকে নিন।
# খালি রাখলে উপরের FACEBOOK_APP_ID/FACEBOOK_APP_SECRET fallback হিসেবে ব্যবহৃত হবে।
META_APP_ID=""
META_APP_SECRET=""
# WhatsApp Embedded Signup configuration ID
# (Meta App → Facebook Login for Business → Configurations)
META_WHATSAPP_CONFIG_ID=""
# Social access token encryption key (AES-256-GCM) — 32-byte random key
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# খালি রাখলে AUTH_SECRET থেকে derive হবে (dev-এর জন্য ঠিক আছে, production-এ আলাদা key দিন)
SOCIAL_TOKEN_ENCRYPTION_KEY=""
# Optional: Graph API version override (default v21.0)
# META_GRAPH_VERSION="v21.0"
# Note: OAuth redirect URIs derive from NEXTAUTH_URL — Meta App-এ whitelist করুন:
#   {NEXTAUTH_URL}/api/integrations/facebook/callback
#   {NEXTAUTH_URL}/api/integrations/whatsapp/callback

# --- Cron ---
# Production-এ অবশ্যই একটি শক্তিশালী random secret দিন (না দিলে cron fail করবে)।
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET="bizilcore-cron"

# --- Blog CMS ---
BLOG_AUTOSAVE_INTERVAL_MS=30000
BLOG_MAX_REVISIONS=50
BLOG_MEDIA_FOLDER=bizilcore/blog

# --- Rate limiting (Upstash Redis — serverless-safe) ---
# খালি রাখলে in-memory fallback (শুধু dev-এর জন্য; serverless production-এ কাজ করবে না)।
# Upstash console → Redis database → REST API থেকে নিন।
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Error monitoring (Sentry) ---
# খালি রাখলে Sentry নিষ্ক্রিয় থাকবে।
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
