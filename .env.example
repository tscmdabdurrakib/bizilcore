SSL_WIRELESS_API_KEY=""
SSL_WIRELESS_SENDER_ID=""

# --- eCourier ---
ECOURIER_API_KEY=""
ECOURIER_API_SECRET=""
ECOURIER_USER_ID=""
ECOURIER_PICKUP_ADDRESS=""

# --- Facebook Integration ---
