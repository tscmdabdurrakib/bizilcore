# ============================================================
# BizilCore - Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   Localhost: copy this file to .env and fill in values
#              cp .env.example .env
#   Replit:    add each key via the Secrets tab (left sidebar)
#              Secrets on Replit NEVER disappear when you push code
# ============================================================

# --- Database ---
# Supabase: use Transaction mode URL (port 6543)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# --- Auth (already configured - same value everywhere) ---
AUTH_SECRET="8371665139ac5457f09fa184a4737e896460968eaaefe3e360034f2ea82cba73"
NEXTAUTH_SECRET="8371665139ac5457f09fa184a4737e896460968eaaefe3e360034f2ea82cba73"
NEXTAUTH_URL="http://localhost:5000"

# --- App URLs ---
NEXT_PUBLIC_APP_URL="http://localhost:5000"
NEXT_PUBLIC_BASE_URL="http://localhost:5000"

# --- Cloudinary (Image Upload) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- AI Features ---
OPENROUTER_API_KEY=""
OPENAI_API_KEY=""

# --- Email ---
EMAIL_FROM_NAME="BizilCore"
# Option A: Gmail SMTP
EMAIL_USER=""
EMAIL_PASS=""
# Option B: Resend
EMAIL_RESEND_API_KEY=""

# --- bKash Payment ---
