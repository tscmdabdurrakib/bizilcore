generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String                      @id @default(cuid())
  name                       String
  email                      String                      @unique
  password                   String
  gender                     String?
  onboarded                  Boolean                     @default(false)
  isAdmin                    Boolean                     @default(false)
  emailVerified              Boolean                     @default(false)
  verifyToken                String?
  verifyTokenExpiry          DateTime?
  resetToken                 String?
  resetTokenExpiry           DateTime?
  createdAt                  DateTime                    @default(now())
  accountStatus              String                      @default("active")
  statusReason               String?
  statusUpdatedAt            DateTime?
  streak                     Int                         @default(0)
  lastLoginDate              String?
  totalOrders                Int                         @default(0)
  reviewRequestedAt          DateTime?
  badges                     String[]                    @default([])
  xpPoints                   Int                         @default(0)
  level                      String                      @default("নতুন বিক্রেতা")
  earnedBadges               UserBadge[]
  notificationPreferences    NotificationPreference?
  setupProgress              Json?                       @default("{}")
  smsDripSentDays            Int[]                       @default([])
  maxShops                   Int                         @default(1)
  shop                       Shop?
  orders                     Order[]
  transactions               Transaction[]
  staffMember                StaffMember?                @relation("StaffUser")
  activityLogs               ActivityLog[]
  subscription               Subscription?
  payments                   Payment[]
  notifications              Notification[]
  stockMovements             StockMovement[]
  orderReturns               OrderReturn[]
  purchases                  Purchase[]
  expenses                   Expense[]
  invoices                   Invoice[]
  purchaseOrders             PurchaseOrder[]
  smsSettings                SmsSettings?
  smsNotificationPreferences SmsNotificationPreferences?
  feedbacks                  UserFeedback[]
  whatsAppSettings           WhatsAppSettings?
  pathaoSettings             PathaoSettings?
  redxSettings               RedxSettings?
  steadfastSettings          SteadfastSettings?
  messageLogs                MessageLog[]
  tasks                      Task[]
  assignedTasks              Task[]                      @relation("AssignedTasks")
  campaignLogs               CampaignLog[]
  taskComments               TaskComment[]
  taskActivityLogs           TaskActivityLog[]
  aiUsage                    AiUsage[]
  promoCodeUsages            PromoCodeUsage[]
  referralCode               ReferralCode?
  referralsMade              Referral[]                  @relation("referrer")
  referralReceived           Referral?                   @relation("referred")
  affiliate                  Affiliate?
  tipReactions               TipReaction[]
  affiliateClicks            AffiliateClick[]
  communityPosts             CommunityPost[]
  communityComments          CommunityComment[]
  communityLikes             CommunityLike[]
  appReviews                 AppReview[]
  npsSurveys                 NPSSurvey[]
}

model AppReview {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating          Int
  title           String?
  body            String?
  improvementNote String?
  businessType    String?
  isApproved      Boolean  @default(false)
  showOnSite      Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([isApproved, showOnSite])
}

model NPSSurvey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Int
  reason    String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Shop {
  id                     String              @id @default(cuid())
  name                   String
  phone                  String?
  email                  String?
  category               String?
  logoUrl                String?
  logoPublicId           String?
  address                String?
  invoiceNote            String?
  bankAccount            String?
  bankName               String?
  slug                   String?             @unique
  slipPrimaryColor       String?             @default("#0d2d1a")
  slipAccentColor        String?             @default("#00e676")
  slipShowBarcode        Boolean             @default(true)
  slipShowQR             Boolean             @default(true)
  slipShowSocialMedia    Boolean             @default(true)
  slipCustomMessage      String?
  slipFacebookPage       String?
  slipWhatsapp           String?
  slipTemplate           String?             @default("classic")
  slipColorPresets       Json?               @default("[]")
  slipShowProductPhotos  Boolean             @default(true)
  slipHideBrandBadge     Boolean             @default(false)
  businessType           String              @default("fcommerce")
  businessConfig         Json?
  activeModules          String[]            @default([])
  salesChannel           String              @default("both")
  userId                 String              @unique
  user                   User                @relation(fields: [userId], references: [id])
  parentShopId           String?
  notifSettings          Json?
  products               Product[]
  customers              Customer[]
  staffMembers           StaffMember[]
  activityLogs           ActivityLog[]
  facebookConnection     FacebookConnection?
  facebookPages          FacebookPage[]
  suggestedOrders        SuggestedOrder[]
  suppliers              Supplier[]
  purchases              Purchase[]
  expenses               Expense[]
  invoices               Invoice[]
  purchaseOrders         PurchaseOrder[]
  attendances            Attendance[]
  shifts                 Shift[]
  tasks                  Task[]
  campaignLogs           CampaignLog[]
  combos                 ComboProduct[]
  branches               ShopBranch[]
  diningTables           DiningTable[]
  menuItems              MenuItem[]
  menuCategories         MenuCategory[]
  restaurantOrders       RestaurantOrder[]
  kotTickets             KotTicket[]
  medicines              Medicine[]
  prescriptions          Prescription[]
  cashRegisters          CashRegister[]
  services               Service[]
  appointments           Appointment[]
  measurements           Measurement[]
  tailorOrders           TailorOrder[]
  storeOrders            StoreOrder[]
  storeReviews           StoreReview[]
  storeCustomers         StoreCustomer[]
  coupons                Coupon[]
  phoneBlacklist         PhoneBlacklist[]
  fakeOrderReports       FakeOrderReport[]
  storePageViews         StorePageView[]
  categories             Category[]          @relation("ShopCategories")
  messengerConversations MessengerConversation[]

  storeSlug         String? @unique
  storeEnabled      Boolean @default(false)
  storeTheme        String  @default("minimal")
  storePrimaryColor String?
  storeAccentColor  String?
  storeBannerUrl    String?
  storeTagline      String?
  storeAbout        String?
  storeShowReviews  Boolean @default(true)
  storeShowStock    Boolean @default(false)
  storeCODEnabled   Boolean @default(true)
  storeBkashNumber  String?
  storeNagadNumber  String?
  storeMinOrder     Float?
  storeFreeShipping Float?
  storeShippingFee  Float   @default(60)
  storeDhakaFee     Float   @default(60)
  storeCustomDomain String?
  storeSocialFB     String?
  storeSocialIG     String?
  storeSocialWA     String?
  storeVisits       Int     @default(0)

  // Hotel module
  rooms             Room[]
  bookings          Booking[]
  housekeepingLogs  HousekeepingLog[]
  hotelCheckInTime    String?  @default("14:00")
  hotelCheckOutTime   String?  @default("11:00")
  hotelLateFeePerHour Float    @default(0)
  hotelEarlyFeePerHour Float   @default(0)
  hotelMinAdvancePct  Int      @default(30)
  hotelAutoHousekeeping Boolean @default(true)

  // Garage module
  vehicles              Vehicle[]
  jobCards              JobCard[]
  garageJobPrefix       String?  @default("JOB")
  garageLaborRate       Float    @default(0)
  garageWarrantyNote    String?
  garageVatNumber       String?
  garageAutoSmsReady    Boolean  @default(true)
  garageCommonServices  Json?    @default("[]")

  // Lab / Diagnostic Center module
  labTests              LabTest[]
  testPackages          TestPackage[]
  testOrders            TestOrder[]
  testResults           TestResult[]
  labOrderPrefix        String?  @default("LAB")
  labAutoSmsReady       Boolean  @default(true)
  labPathologistName    String?
  labRegistrationNo     String?

  // Convention Hall / Event module
  halls                 Hall[]
  eventPackages         EventPackage[]
  hallEvents            HallEvent[]
  conventionEventPrefix String?  @default("EVT")
  conventionMinAdvancePct Int    @default(30)

  // School / Coaching Center module
  students              Student[]
  batches               Batch[]
  feeRecords            FeeRecord[]
  attendanceRecords     AttendanceRecord[]
  examResults           ExamResult[]
  mealRecords           MealRecord[]
  dailyReports          DailyReport[]
  schoolRegPrefix       String?  @default("STU")
  schoolReceiptPrefix   String?  @default("REC")
  schoolFeeDueDay       Int      @default(10)
  schoolLateFeeAmount   Float    @default(0)
  schoolAutoGenerateFee Boolean  @default(false)
  schoolAbsentSms       Boolean  @default(false)
  schoolInstitutionType String?  @default("coaching")
  schoolAcademicYear    String?  @default("January - December")
  // Kindergarten extras
  kgOpenTime            String?  @default("08:00")
  kgCloseTime           String?  @default("14:00")
  kgBreakfastTime       String?  @default("09:00")
  kgLunchTime           String?  @default("12:00")
  kgSnackTime           String?  @default("13:00")
  kgAbsentSms           Boolean  @default(false)
  kgDailyReportSms      Boolean  @default(false)
  kgReportSendTime      String?  @default("15:00")
  kgSections            String[] @default(["Playgroup","Nursery","KG-1","KG-2","Pre-School"])
  lands                 Land[]
  cropCycles            CropCycle[]
  farmActivityLogs      FarmActivityLog[]
  harvestRecords        HarvestRecord[]
  harvestSales          HarvestSale[]
  livestocks            Livestock[]
  livestockLogs         LivestockLog[]
  farmType              String?  @default("mixed")
  farmAreaUnit          String?  @default("bigha")
  farmWeightUnit        String?  @default("kg")
  farmVaccinationDays   Int      @default(7)

  // Hospital / Clinic module
  doctors               Doctor[]
  patients              HospitalPatient[]
  opdVisits             OPDVisit[]
  ipdAdmissions         IPDAdmission[]
  beds                  Bed[]
  hospitalFacilityType  String?  @default("hospital")
  hospitalRegNumber     String?
  hospitalEmergencyPhone String?
  hospitalTokenResetTime String? @default("00:00")
  hospitalAdmissionPrefix String? @default("IPD")
  hospitalOpdPrefix     String?  @default("OPD")
  hospitalPatientPrefix String?  @default("PAT")
  hospitalShowVitals    Boolean  @default(true)
  hospitalAutoSms       Boolean  @default(false)

  // Travel Agency module
  tourPackages          TourPackage[]
  tourBookings          TourBooking[]
  visaRequests          VisaRequest[]
  travelVendors         TravelVendor[]
  travelBookingPrefix   String?  @default("TRV")
  travelVisaPrefix      String?  @default("VISA")
  travelAutoSms         Boolean  @default(true)
  // Gym relations & config
  gymMembers            Member[]
  gymTrainers           GymTrainer[]
  gymEquipments         Equipment[]
  membershipPlans       MembershipPlan[]
  gymMemberPrefix       String?  @default("GYM")
  gymOpenTime           String?  @default("06:00")
  gymCloseTime          String?  @default("22:00")
  gymExpiryAlertDays    Int      @default(7)
  gymAutoSmsExpiry      Boolean  @default(true)

  // Photography / Videography module
  photoPackages         PhotoPackage[]
  photoBookings         PhotoBooking[]
  photoEquipments       PhotoEquipment[]
  photoBookingPrefix    String?  @default("PHO")
  photoAutoSms          Boolean  @default(true)
  photoStudioName       String?

  // Printing / Press module
  printServices         PrintService[]
  printOrders           PrintOrder[]
  printOrderPrefix      String?  @default("PRT")
  printDeliveryDays     Int      @default(3)
  printUrgentDays       Int      @default(1)
  printUrgentSurcharge  Float    @default(0)
  printRequireApproval  Boolean  @default(true)
  printMinAdvancePct    Int      @default(50)
  printAutoSms          Boolean  @default(true)

  // Real Estate module
  properties              Property[]
  propertyOwners          PropertyOwner[]
  propertyLeads           PropertyLead[]
  deals                   Deal[]
  propPrefix              String?  @default("PROP")
  dealPrefix              String?  @default("DEAL")
  defaultSaleCommission   Float    @default(2)
  defaultRentCommission   Float    @default(50)
  propAreaUnit            String?  @default("sqft")
  propAutoSms             Boolean  @default(true)

  // Pet Shop / Veterinary module
  pets                    Pet[]
  petHealthLogs           PetHealthLog[]
  petAppointments         PetAppointment[]
  petAutoSms              Boolean  @default(true)
  petReminderDays         Int      @default(1)

  // Electronics Repair module
  devices                 Device[]
  electronicsJobPrefix    String?  @default("ELC")
  electronicsAutoSmsReady Boolean  @default(true)
  electronicsWarrantyDays Int      @default(30)

  // Car Rental module
  rentalVehicles          RentalVehicle[]
  rentalDrivers           RentalDriver[]
  rentalBookings          RentalBooking[]
  fuelLogs                FuelLog[]
  rentalPayments          RentalPayment[]
  carBookingPrefix        String?  @default("CAR")
  carExtraKmRate          Float    @default(5)
  carExtraHrRate          Float    @default(100)
  carMinAdvancePct        Int      @default(30)
  carAutoSms              Boolean  @default(true)
  carServiceDays          Int      @default(30)

  // Legal / Lawyer Chamber module
  legalCases              LegalCase[]
  legalCasePrefix         String?  @default("CASE")
  legalBarCouncilNo       String?
  legalHearingReminderDays Int     @default(2)
  legalAutoSmsClient      Boolean  @default(true)
  legalChamberName        String?

  // Spa / Wellness Center module
  treatmentRooms          TreatmentRoom[]
  spaBookingPrefix        String?  @default("SPA")
  spaSlotDuration         Int      @default(30)
  spaCleaningBuffer       Int      @default(15)
  spaCoupleEnabled        Boolean  @default(true)
  spaGenderPrefEnabled    Boolean  @default(true)
  spaAdvanceBookingDays   Int      @default(0)
  spaOpenTime             String?  @default("09:00")
  spaCloseTime            String?  @default("21:00")

  // Catering Service module
  cateringEvents           CateringEvent[]
  cateringMenuTemplates    CateringMenuTemplate[]
  cateringBookingPrefix    String?  @default("CAT")
  cateringDefaultMargin    Float    @default(30)
  cateringMinAdvancePct    Int      @default(40)
  cateringAutoShoppingList Boolean  @default(true)
  cateringStaffPer100      Int      @default(10)

  // IT / Freelance module
  freelanceProjects        FreelanceProject[]
  freelanceInvoices        FreelanceInvoice[]
  timeLogs                 TimeLog[]
  freelanceProjectPrefix   String?  @default("PRJ")
  freelanceInvoicePrefix   String?  @default("INV")
  freelanceDefaultCurrency String?  @default("BDT")
  freelanceDefaultHourlyRate Float  @default(0)
  freelancePaymentInstructions String?
  freelanceTaxRate         Float    @default(0)
  freelanceInvoiceReminderDays Int  @default(3)

  // Restaurant module (extended)
  rawMaterials             RawMaterial[]
  purchaseEntries          PurchaseEntry[]
  posShifts                PosShift[]
  restOrderPrefix          String?  @default("RES")
  restVatPct               Float    @default(0)
  restServiceChargePct     Float    @default(0)
  restKotAutoSend          Boolean  @default(false)
  restCurrency             String?  @default("BDT")
  restDefaultFloors        String[] @default(["Ground"])
  restDeliveryEnabled      Boolean  @default(true)
  restAutoStockDeduct      Boolean  @default(true)
  restRequireShift              Boolean  @default(false)
  managerPin                    String?
  managerDiscountThreshold      Float    @default(20)
  restVoidThresholdHours        Int      @default(24)
  // Receipt / thermal print settings
  receiptLogo              String?
  receiptHeaderLine1       String?
  receiptHeaderLine2       String?
  receiptFooter            String?  @default("ধন্যবাদ! আবার আসবেন।")
  receiptPaperSize         String?  @default("80mm")
  receiptShowVat           Boolean  @default(true)
  receiptShowQr            Boolean  @default(true)
  receiptShowLogo          Boolean  @default(true)
}

model Subscription {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id])
  plan      String    @default("free")
  status    String    @default("active")
  startDate DateTime  @default(now())
  endDate   DateTime?
  autoRenew Boolean   @default(false)
}

model Payment {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id])
  amount         Float
  originalAmount Float?
  discountAmount Float?
  promoCodeId    String?
  promoCode      PromoCode? @relation(fields: [promoCodeId], references: [id])
  promoCodeStr   String?
  method         String
  transactionId  String?
  senderPhone    String?
  plan           String
  months         Int        @default(1)
  status         String     @default("pending")
  adminNote      String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model StaffMember {
  id               String            @id @default(cuid())
  shopId           String
  shop             Shop              @relation(fields: [shopId], references: [id])
  userId           String            @unique
  user             User              @relation("StaffUser", fields: [userId], references: [id])
  role             String
  inviteToken      String?           @unique
  invitedAt        DateTime          @default(now())
  joinedAt         DateTime?
  isActive         Boolean           @default(true)
  salary           Float?
  jobTitle         String?
  phone            String?
  attendances      Attendance[]
  shiftAssignments ShiftAssignment[]
  appointments     Appointment[]
  defaultServices  Service[]         @relation("ServiceDefaultStaff")
  teachingBatches  Batch[]           @relation("BatchTeacher")
  assignedOrders   RestaurantOrder[]

  @@index([shopId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  detail    String?
  createdAt DateTime @default(now())

  @@index([shopId])
  @@index([createdAt])
}

model Product {
  id              String            @id @default(cuid())
  name            String
  sku             String?
  description     String?
  buyPrice        Float
  sellPrice       Float
  stockQty        Int               @default(0)
  lowStockAt      Int               @default(5)
  category        String?
  categoryId      String?
  categoryRef     Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull, name: "ProductCategory")
  imageUrl        String?
  images          Json?
  hasVariants     Boolean           @default(false)
  storeVisible    Boolean           @default(true)
  storeFeatured   Boolean           @default(false)
  shopId          String
  shop            Shop              @relation(fields: [shopId], references: [id])
  orderItems      OrderItem[]
  stockMovements  StockMovement[]
  returnItems     OrderReturnItem[]
  purchaseItems   PurchaseItem[]
  variants        ProductVariant[]
  comboItems      ComboItem[]
  storeOrderItems StoreOrderItem[]
  storeReviews    StoreReview[]
  jobCardParts    JobCardPart[]
  isDemoData      Boolean           @default(false)
  createdAt       DateTime          @default(now())

  @@index([shopId])
  @@index([createdAt])
  @@index([categoryId])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  size       String?
  color      String?
  sku        String?
  price      Float?
  buyPrice   Float?
  stockQty   Int         @default(0)
  createdAt  DateTime    @default(now())
  comboItems ComboItem[]

  @@index([productId])
}

model Customer {
  id            String         @id @default(cuid())
  name          String
  phone         String?
  address       String?
  fbProfile     String?
  dueAmount     Float          @default(0)
  group         String         @default("regular")
  loyaltyPoints Int            @default(0)
  lastOrderAt   DateTime?
  shopId        String
  shop          Shop           @relation(fields: [shopId], references: [id])
  orders        Order[]
  invoices      Invoice[]
  messageLogs   MessageLog[]
  prescriptions Prescription[]
  appointments  Appointment[]
  measurements  Measurement[]
  tailorOrders  TailorOrder[]
  bookings      Booking[]
  vehicles      Vehicle[]
  testOrders    TestOrder[]
  hallEvents    HallEvent[]    @relation("CustomerHallEvents")
  harvestSales  HarvestSale[]
  tourBookings  TourBooking[]
  visaRequests  VisaRequest[]
  photoBookings PhotoBooking[]
  printOrders   PrintOrder[]
  pets          Pet[]
  devices       Device[]
  rentalBookings RentalBooking[]
  legalCases    LegalCase[]
  cateringEvents CateringEvent[]
  freelanceProjects FreelanceProject[]
  freelanceInvoices FreelanceInvoice[]
  isDemoData    Boolean        @default(false)
  createdAt     DateTime       @default(now())

  @@index([shopId])
  @@index([createdAt])
  @@index([group])
}

model Order {
  id              String        @id @default(cuid())
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  status          String        @default("pending")
  source          String        @default("facebook")
  codStatus       String?
  codRemitted     Boolean       @default(false)
  codRemittedAt   DateTime?
  courierName     String?
  courierTrackId  String?
  courierStatus   String?
  courierBookedAt DateTime?
  totalAmount     Float
  paidAmount      Float         @default(0)
  dueAmount       Float         @default(0)
  deliveryCharge  Float         @default(0)
  tags            String?       @default("[]")
  note            String?
  storeOrderId    String?       @unique
  storeOrder      StoreOrder?   @relation(fields: [storeOrderId], references: [id])
  riskScore       Float?
  riskFlags       String?
  fakeReported    Boolean       @default(false)
  items           OrderItem[]
  returns         OrderReturn[]
  tasks           Task[]
  isDemoData      Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id])
  productId     String?
  product       Product?      @relation(fields: [productId], references: [id])
  comboId       String?
  combo         ComboProduct? @relation(fields: [comboId], references: [id])
  comboSnapshot String?
  quantity      Int
  unitPrice     Float
  subtotal      Float
}

model ComboProduct {
  id          String      @id @default(cuid())
  shopId      String
  shop        Shop        @relation(fields: [shopId], references: [id])
  name        String
  description String?
  sellPrice   Float
  imageUrl    String?
  isActive    Boolean     @default(true)
  items       ComboItem[]
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())

  @@index([shopId])
  @@index([isActive])
}

model ComboItem {
  id        String          @id @default(cuid())
  comboId   String
  combo     ComboProduct    @relation(fields: [comboId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int

  @@index([comboId])
  @@index([productId])
  @@index([variantId])
}

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  quantity  Int
  reason    String?
  orderId   String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
}

model OrderReturn {
  id        String            @id @default(cuid())
  orderId   String
  order     Order             @relation(fields: [orderId], references: [id])
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  reason    String?
  restock   Boolean           @default(true)
  items     OrderReturnItem[]
  createdAt DateTime          @default(now())

  @@index([orderId])
  @@index([userId])
}

model OrderReturnItem {
  id        String      @id @default(cuid())
  returnId  String
  return    OrderReturn @relation(fields: [returnId], references: [id])
  productId String
  product   Product     @relation(fields: [productId], references: [id])
  quantity  Int
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  amount    Float
  category  String?
  note      String?
  taxAmount Float    @default(0)
  taxRate   Float    @default(0)
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  phone          String?
  address        String?
  email          String?
  note           String?
  dueAmount      Float           @default(0)
  shopId         String
  shop           Shop            @relation(fields: [shopId], references: [id])
  purchases      Purchase[]
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())

  @@index([shopId])
  @@index([createdAt])
}

model Purchase {
  id          String         @id @default(cuid())
  supplierId  String?
  supplier    Supplier?      @relation(fields: [supplierId], references: [id])
  shopId      String
  shop        Shop           @relation(fields: [shopId], references: [id])
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  totalAmount Float
  paidAmount  Float          @default(0)
  dueAmount   Float          @default(0)
  note        String?
  status      String         @default("pending")
  items       PurchaseItem[]
  createdAt   DateTime       @default(now())

  @@index([shopId])
  @@index([userId])
  @@index([supplierId])
  @@index([createdAt])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String?
  product    Product? @relation(fields: [productId], references: [id])
  name       String
  quantity   Int
  unitPrice  Float
  subtotal   Float
}

model FacebookConnection {
  id          String   @id @default(cuid())
  shopId      String   @unique
  shop        Shop     @relation(fields: [shopId], references: [id])
  pageId      String
  pageName    String
  accessToken String
  connectedAt DateTime @default(now())
  isActive    Boolean  @default(true)
}

model FacebookPage {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  pageId      String
  pageName    String
  accessToken String
  category    String?
  followers   Int?
  connectedAt DateTime @default(now())
  isActive    Boolean  @default(true)
  autoReply   Boolean  @default(false)
  replyMessage String? @default("আপনার বার্তার জন্য ধন্যবাদ! আমরা শীঘ্রই যোগাযোগ করব। 🙏")

  messengerConversations MessengerConversation[]

  @@unique([shopId, pageId])
  @@index([shopId])
}

model MessengerConversation {
  id             String       @id @default(cuid())
  shopId         String
  shop           Shop         @relation(fields: [shopId], references: [id])
  facebookPageId String
  facebookPage   FacebookPage @relation(fields: [facebookPageId], references: [id])
  fbPageId       String
  senderId       String
  senderName     String?
  message        String
  reply          String?
  repliedAt      DateTime?
  createdAt      DateTime     @default(now())

  @@index([shopId])
  @@index([facebookPageId])
  @@index([createdAt])
}

model SuggestedOrder {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id])
  commenterName String
  commenterFbId String?
  commentText   String
  postId        String?
  commentId     String?  @unique
  fbProfile     String?
  pageName      String?
  status        String   @default("pending")
  createdAt     DateTime @default(now())

  @@index([shopId])
  @@index([status])
  @@index([createdAt])
}

model Expense {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  amount    Float
  category  String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())

  @@index([shopId])
  @@index([category])
  @@index([date])
}

model Invoice {
  id            String        @id @default(cuid())
  shopId        String
  shop          Shop          @relation(fields: [shopId], references: [id])
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id])
  invoiceNumber String
  status        String        @default("draft")
  items         InvoiceItem[]
  subtotal      Float
  discount      Float         @default(0)
  total         Float
  notes         String?
  dueDate       DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  @@index([shopId])
  @@index([status])
  @@index([createdAt])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Float
  subtotal    Float
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  shopId       String
  shop         Shop                @relation(fields: [shopId], references: [id])
  userId       String
  user         User                @relation(fields: [userId], references: [id])
  supplierId   String?
  supplier     Supplier?           @relation(fields: [supplierId], references: [id])
  poNumber     String
  status       String              @default("draft")
  items        PurchaseOrderItem[]
  total        Float
  notes        String?
  expectedDate DateTime?
  receivedAt   DateTime?
  createdAt    DateTime            @default(now())

  @@index([shopId])
  @@index([status])
  @@index([createdAt])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  name            String
  quantity        Int
  unitPrice       Float
  subtotal        Float
}

model Attendance {
  id        String      @id @default(cuid())
  shopId    String
  shop      Shop        @relation(fields: [shopId], references: [id])
  staffId   String
  staff     StaffMember @relation(fields: [staffId], references: [id])
  date      DateTime    @db.Date
  checkIn   DateTime?
  checkOut  DateTime?
  status    String      @default("present")
  notes     String?
  createdAt DateTime    @default(now())

  @@unique([staffId, date])
  @@index([shopId])
  @@index([staffId])
  @@index([date])
}

model Shift {
  id               String            @id @default(cuid())
  shopId           String
  shop             Shop              @relation(fields: [shopId], references: [id])
  title            String
  startTime        String
  endTime          String
  days             Json
  color            String            @default("#0F6E56")
  createdAt        DateTime          @default(now())
  shiftAssignments ShiftAssignment[]

  @@index([shopId])
}

model ShiftAssignment {
  id        String      @id @default(cuid())
  shiftId   String
  shift     Shift       @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  staffId   String
  staff     StaffMember @relation(fields: [staffId], references: [id])
  weekStart DateTime    @db.Date
  createdAt DateTime    @default(now())

  @@unique([shiftId, staffId, weekStart])
}

model SmsSettings {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey      String?
  isConnected Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model SmsNotificationPreferences {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderConfirmed     Boolean  @default(true)
  orderStatusChanged Boolean  @default(false)
  deliveryConfirmed  Boolean  @default(false)
  paymentReceived    Boolean  @default(false)
  lowStockAlert      Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

model WhatsAppSettings {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiToken          String?
  phoneNumberId     String?
  businessAccountId String?
  isConnected       Boolean   @default(false)
  connectedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
}

model PathaoSettings {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId        String?
  clientSecret    String?
  username        String?
  password        String?
  storeId         String?
  sandboxMode     Boolean   @default(false)
  isConnected     Boolean   @default(false)
  connectedAt     DateTime?
  defaultCityId   Int       @default(1)
  defaultZoneId   Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
}

model RedxSettings {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey      String?
  isConnected Boolean   @default(false)
  connectedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

model SteadfastSettings {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isConnected Boolean   @default(false)
  apiKey      String?
  secretKey   String?
  connectedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
}

model MessageLog {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  toPhone      String
  message      String
  status       String    @default("pending")
  errorMessage String?
  sentAt       DateTime  @default(now())

  @@index([userId])
  @@index([sentAt])
}

model UserFeedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "bug" | "suggestion" | "compliment" | "other"
  message   String
  pageUrl   String?
  status    String   @default("new") // "new" | "seen" | "resolved"
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model CampaignLog {
  id             String   @id @default(cuid())
  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  segment        String
  channel        String
  message        String
  recipientCount Int      @default(0)
  sentAt         DateTime @default(now())

  @@index([shopId])
  @@index([sentAt])
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  status       String   @default("active") // active | unsubscribed
  subscribedAt DateTime @default(now())

  @@index([status])
  @@index([subscribedAt])
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskCategory {
  order
  delivery
  supplier
  accounts
  general
}

enum RecurrenceType {
  none
  daily
  weekly
  monthly
}

model Task {
  id               String            @id @default(cuid())
  shopId           String
  shop             Shop              @relation(fields: [shopId], references: [id])
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  title            String
  description      String?
  status           TaskStatus        @default(todo)
  priority         TaskPriority      @default(medium)
  category         TaskCategory      @default(general)
  assignedToId     String?
  assignedTo       User?             @relation("AssignedTasks", fields: [assignedToId], references: [id])
  tags             String[]          @default([])
  attachments      String[]          @default([])
  dueDate          DateTime?
  reminderAt       DateTime?
  reminderSent     Boolean           @default(false)
  completedAt      DateTime?
  recurring        Boolean           @default(false)
  recurrence       RecurrenceType    @default(none)
  orderId          String?
  order            Order?            @relation(fields: [orderId], references: [id])
  estimatedMinutes Int?
  actualMinutes    Int?
  comments         TaskComment[]
  activityLogs     TaskActivityLog[]
  subtasks         SubTask[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([shopId])
  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([createdAt])
}

model SubTask {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([taskId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([createdAt])
}

model TaskActivityLog {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  detail    String?
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([createdAt])
}

model AiUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  feature   String
  model     String
  date      String
  createdAt DateTime @default(now())

  @@index([userId, date])
}

model PromoCode {
  id              String           @id @default(cuid())
  code            String           @unique
  description     String?
  discountType    String           @default("PERCENT")
  discountValue   Float
  maxUses         Int?
  maxUsesPerUser  Int              @default(1)
  usedCount       Int              @default(0)
  validFrom       DateTime?
  validTo         DateTime?
  minAmount       Float?
  applicablePlans String?
  baseMonths      Int?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  usages          PromoCodeUsage[]
  payments        Payment[]

  @@index([code])
  @@index([isActive])
}

model PricingConfig {
  id              String   @id @default(cuid())
  planKey         String   @unique
  monthlyPrice    Int      @default(0)
  yearlyPrice     Int      @default(0)
  discountEnabled Boolean  @default(false)
  discountPercent Int      @default(0)
  discountLabel   String   @default("")
  updatedAt       DateTime @updatedAt
}

model PromoCodeUsage {
  id             String    @id @default(cuid())
  promoCodeId    String
  promoCode      PromoCode @relation(fields: [promoCodeId], references: [id])
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  discountAmount Float
  originalAmount Float
  finalAmount    Float
  usedAt         DateTime  @default(now())

  @@unique([promoCodeId, userId])
  @@index([userId])
  @@index([promoCodeId])
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  code      String   @unique
  uses      Int      @default(0)
  earnings  Float    @default(0)
  createdAt DateTime @default(now())

  @@index([code])
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referrer    User     @relation("referrer", fields: [referrerId], references: [id])
  referredId  String   @unique
  referred    User     @relation("referred", fields: [referredId], references: [id])
  reward      String   @default("1_month_pro")
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([referrerId])
}

model Affiliate {
  id             String            @id @default(cuid())
  userId         String            @unique
  user           User              @relation(fields: [userId], references: [id])
  slug           String            @unique
  status         String            @default("pending")
  commissionRate Float             @default(0.1)
  totalClicks    Int               @default(0)
  totalSignups   Int               @default(0)
  totalEarnings  Float             @default(0)
  pendingPayout  Float             @default(0)
  bkashNumber    String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime          @default(now())
  clicks         AffiliateClick[]
  payouts        AffiliatePayout[]

  @@index([status])
}

model AffiliatePayout {
  id          String    @id @default(cuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  amount      Float
  bkashNumber String
  status      String    @default("pending")
  note        String?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([affiliateId])
}

model ShopBranch {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id])
  name      String
  category  String?
  phone     String?
  address   String?
  logoUrl   String?
  note      String?
  createdAt DateTime @default(now())

  @@index([shopId])
}

model AffiliateClick {
  id          String    @id @default(cuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  ip          String?
  userAgent   String?
  converted   Boolean   @default(false)
  plan        String?
  commission  Float?
  createdAt   DateTime  @default(now())

  @@index([affiliateId])
  @@index([userId])
  @@index([createdAt])
}

model CommunityTip {
  id         String        @id @default(cuid())
  title      String
  body       String
  category   String?
  week       String?
  helpful    Int           @default(0)
  notHelpful Int           @default(0)
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  reactions  TipReaction[]

  @@index([isActive])
  @@index([category])
}

model TipReaction {
  id        String       @id @default(cuid())
  tipId     String
  tip       CommunityTip @relation(fields: [tipId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reaction  String
  createdAt DateTime     @default(now())

  @@unique([tipId, userId])
  @@index([tipId])
}

model DiningTable {
  id               String            @id @default(cuid())
  shopId           String
  shop             Shop              @relation(fields: [shopId], references: [id])
  number           Int
  capacity         Int               @default(4)
  status           String            @default("available")
  floor            String?           @default("Ground")
  restaurantOrders RestaurantOrder[]

  @@index([shopId])
}

model MenuItem {
  id             String                @id @default(cuid())
  shopId         String
  shop           Shop                  @relation(fields: [shopId], references: [id])
  menuCategoryId String?
  menuCategory   MenuCategory?         @relation(fields: [menuCategoryId], references: [id])
  name           String
  nameEn         String?
  category       String                @default("main")
  price          Float
  costPrice      Float?
  imageUrl       String?
  isAvailable    Boolean               @default(true)
  isVeg          Boolean               @default(false)
  prepMinutes    Int                   @default(15)
  variants       Json?
  addons         Json?
  orderItems     RestaurantOrderItem[]
  recipes        Recipe[]
  createdAt      DateTime              @default(now())

  @@index([shopId])
  @@index([shopId, category])
  @@index([menuCategoryId])
}

model RestaurantOrder {
  id            String                @id @default(cuid())
  shopId        String
  shop          Shop                  @relation(fields: [shopId], references: [id])
  tableId       String?
  table         DiningTable?          @relation(fields: [tableId], references: [id])
  waiterId      String?
  waiter        StaffMember?          @relation(fields: [waiterId], references: [id])
  orderNumber   String?               @unique
  type          String                @default("dine_in")
  status        String                @default("pending")
  billRequested Boolean               @default(false)
  items         RestaurantOrderItem[]
  kotTickets    KotTicket[]
  splits        OrderSplit[]
  subtotal      Float                 @default(0)
  discount      Float                 @default(0)
  vatAmount     Float                 @default(0)
  serviceAmount Float                 @default(0)
  totalAmount   Float
  paidAmount    Float                 @default(0)
  dueAmount     Float                 @default(0)
  tipAmount     Float                 @default(0)
  paymentMethod String?               @default("cash")
  kotSent       Boolean               @default(false)
  kotSentAt     DateTime?
  customerName  String?
  customerPhone String?
  note          String?
  isVoided      Boolean               @default(false)
  voidedAt      DateTime?
  voidReason    String?
  voidedBy      String?
  refundedAt    DateTime?
  refundAmount  Float?
  refundReason  String?
  refundedBy    String?
  isHeld            Boolean               @default(false)
  heldAt            DateTime?
  heldBy            String?
  discountBreakdown Json?
  couponCode        String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([shopId])
  @@index([shopId, status])
  @@index([shopId, createdAt])
  @@index([shopId, waiterId])
  @@index([shopId, isVoided])
  @@index([shopId, isHeld])
}

model OrderSplit {
  id            String          @id @default(cuid())
  orderId       String
  order         RestaurantOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  splitIndex    Int
  payerName     String?
  amount        Float
  paymentMethod String          @default("cash")
  transactionRef String?
  paidAt        DateTime        @default(now())

  @@index([orderId])
}

model PosShift {
  id             String           @id @default(cuid())
  shopId         String
  shop           Shop             @relation(fields: [shopId], references: [id])
  shiftNumber    String
  openedBy       String
  openedById     String?
  closedBy       String?
  closedById     String?
  openedAt       DateTime         @default(now())
  closedAt       DateTime?
  openingCash    Float            @default(0)
  countedCash    Float?
  expectedCash   Float            @default(0)
  cashOver       Float?
  cashShort      Float?
  status         String           @default("open")
  notes          String?
  createdAt      DateTime         @default(now())
  logs           CashDrawerLog[]

  @@unique([shopId, shiftNumber])
  @@index([shopId])
  @@index([shopId, status])
}

model CashDrawerLog {
  id          String   @id @default(cuid())
  shopId      String
  shiftId     String
  shift       PosShift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  type        String
  amount      Float    @default(0)
  note        String?
  performedBy String?
  loggedAt    DateTime @default(now())

  @@index([shopId])
  @@index([shiftId])
}

model KotTicket {
  id            String          @id @default(cuid())
  shopId        String
  shop          Shop            @relation(fields: [shopId], references: [id])
  orderId       String
  order         RestaurantOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  kotNumber     String
  items         Json
  kitchenStatus String          @default("pending")
  sentAt        DateTime        @default(now())
  note          String?

  @@index([shopId])
  @@index([orderId])
}

model RestaurantOrderItem {
  id              String          @id @default(cuid())
  orderId         String
  order           RestaurantOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId      String
  menuItem        MenuItem        @relation(fields: [menuItemId], references: [id])
  quantity        Int
  unitPrice       Float
  selectedVariant String?
  selectedAddons  Json?
  addonTotal      Float           @default(0)
  note            String?
  isVoided        Boolean         @default(false)
}

model MenuCategory {
  id        String     @id @default(cuid())
  shopId    String
  shop      Shop       @relation(fields: [shopId], references: [id])
  name      String
