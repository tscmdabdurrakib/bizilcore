{
  "framework": "nextjs",
  "buildCommand": "npm run build:vercel",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    { "path": "/api/cron/check-subscriptions", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/referrer-rewards", "schedule": "30 2 * * *" },
    { "path": "/api/cron/refresh-social-tokens", "schedule": "0 3 * * *" },
    { "path": "/api/cron/abandoned-cart", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/publish-posts", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/daily-backup", "schedule": "0 18 * * *" },
    { "path": "/api/cron/invoice-overdue", "schedule": "0 1 * * *" },
    { "path": "/api/cron/recurring-invoices", "schedule": "0 2 * * *" },
    { "path": "/api/cron/recurring-expenses", "schedule": "0 2 * * *" },
    { "path": "/api/cron/po-reminders", "schedule": "0 4 * * *" },
    { "path": "/api/cron/back-in-stock", "schedule": "0 */2 * * *" },
    { "path": "/api/cron/sms-drip", "schedule": "0 6 * * *" },
    { "path": "/api/notifications/plan-expiry", "schedule": "0 7 * * *" },
    { "path": "/api/notifications/weekly-tip", "schedule": "0 8 * * 1" }
  ]
}
